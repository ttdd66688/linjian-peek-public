<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/app_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="掌心窗" android:textStyle="bold" android:textSize="26sp" android:textColor="#FF2F403B" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="v0.2.1 · 连招、悬浮横幅、应用包名和强制抱回。" android:textSize="13sp" android:textColor="#FF77908A" android:layout_marginTop="2dp" />
        <TextView android:id="@+id/statusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="状态加载中…" android:textSize="14sp" android:textColor="#FF60746F" android:background="@drawable/card_bg" android:layout_marginTop="5dp" android:lineSpacingExtra="3dp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="12dp"
        android:paddingRight="12dp">

        <ScrollView android:id="@+id/sectionSettings" android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="连接设置" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="填后端和 Token。截图、控制、生活状态、动作序列都走这一扇窗。" android:textSize="13sp" android:textColor="#FF7A8F89" android:layout_marginTop="4dp" android:lineSpacingExtra="3dp" />
                    <EditText android:id="@+id/serverUrl" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="统一后端地址，例如 https://example.onrender.com" android:textSize="14sp" android:inputType="textUri" android:singleLine="true" android:layout_marginTop="5dp" />
                    <EditText android:id="@+id/tokenInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Token" android:textSize="14sp" android:inputType="textPassword" android:singleLine="true" />
                    <EditText android:id="@+id/deviceInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="设备 ID，默认 android-phone" android:textSize="14sp" android:singleLine="true" />
                    <EditText android:id="@+id/intervalInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="轮询间隔 ms，建议 1000-3000" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="权限与运行" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="无障碍用于截图、读当前包名、返回/主页/最近任务/点击/滑动；使用情况访问用于屏幕时间和 Top App。" android:textSize="13sp" android:textColor="#FF7A8F89" android:layout_marginTop="5dp" android:lineSpacingExtra="4dp" />
                    <CheckBox android:id="@+id/foregroundPopupEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="所有通知优先悬浮横幅提醒" android:textSize="15sp" android:checked="true" android:layout_marginTop="5dp" />
                    <Button android:id="@+id/accessibilityButton" android:layout_width="match_parent" android:layout_height="44dp" android:text="打开无障碍设置" android:textSize="14sp" android:layout_marginTop="5dp" android:background="@drawable/pill_soft" />
                    <Button android:id="@+id/usageAccessButton" android:layout_width="match_parent" android:layout_height="44dp" android:text="打开使用情况访问权限" android:textSize="14sp" android:layout_marginTop="5dp" android:background="@drawable/pill_soft" />
                    <Button android:id="@+id/toggleButton" android:layout_width="match_parent" android:layout_height="46dp" android:text="启动" android:textSize="14sp" android:textColor="#FFFFFFFF" android:background="@drawable/pill_primary" android:layout_marginTop="5dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView android:id="@+id/sectionSee" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="看见" android:textStyle="bold" android:textSize="20sp" android:textColor="#FF3E514B" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="等待 peek、截图上传、读取最近屏幕。适合陪刷帖子、确认当前页面。" android:textSize="13sp" android:textColor="#FF7A8F89" android:layout_marginTop="5dp" android:lineSpacingExtra="4dp" />
                    <Button android:id="@+id/testButton" android:layout_width="match_parent" android:layout_height="44dp" android:text="测试截图上传" android:textSize="14sp" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView android:id="@+id/sectionControl" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="控制台" android:textStyle="bold" android:textSize="20sp" android:textColor="#FF3E514B" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="这里像抽屉一样分成几块：本机按钮、应用包名、连招测试。日志会写清哪一步失败。" android:textSize="13sp" android:textColor="#FF7A8F89" android:layout_marginTop="5dp" android:lineSpacingExtra="4dp" />
                    <Button android:id="@+id/openChatGptButton" android:layout_width="match_parent" android:layout_height="42dp" android:text="本机测试：打开目标 App" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                    <Button android:id="@+id/openXhsButton" android:layout_width="match_parent" android:layout_height="42dp" android:text="本机测试：打开小红书" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                    <Button android:id="@+id/recentsButton" android:layout_width="match_parent" android:layout_height="42dp" android:text="本机测试：最近任务" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                    <Button android:id="@+id/homeButton" android:layout_width="match_parent" android:layout_height="42dp" android:text="本机测试：回桌面" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                    <Button android:id="@+id/backButton" android:layout_width="match_parent" android:layout_height="42dp" android:text="本机测试：返回" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="应用包名抽屉" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="能打开哪些应用会列在这里。新增包名后，MCP 可用 app 昵称或 package 打开。" android:textSize="13sp" android:textColor="#FF7A8F89" android:layout_marginTop="5dp" android:lineSpacingExtra="4dp" />
                    <TextView android:id="@+id/knownAppsText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="加载中…" android:textSize="12sp" android:textColor="#FF4F5F5A" android:background="#FFF1F6F4" android:padding="10dp" android:layout_marginTop="5dp" android:lineSpacingExtra="3dp" />
                    <EditText android:id="@+id/appAliasInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="应用昵称，例如 微博 / B站 / 学习通" android:textSize="14sp" android:singleLine="true" android:layout_marginTop="5dp" />
                    <EditText android:id="@+id/appPackageInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="包名，例如 com.xingin.xhs" android:textSize="14sp" android:singleLine="true" />
                    <Button android:id="@+id/addPackageButton" android:layout_width="match_parent" android:layout_height="42dp" android:text="添加/更新这个包名" android:background="@drawable/pill_primary" android:textColor="#FFFFFFFF" android:layout_marginTop="5dp" />
                    <Button android:id="@+id/testPackageButton" android:layout_width="match_parent" android:layout_height="42dp" android:text="测试打开填写的包名" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="连招测试" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="MCP 的 run_sequence 会逐步执行并回报。这里先做本机轻测试：悬浮横幅 + 打开目标 App。" android:textSize="13sp" android:textColor="#FF7A8F89" android:layout_marginTop="5dp" android:lineSpacingExtra="4dp" />
                    <Button android:id="@+id/sequenceTestButton" android:layout_width="match_parent" android:layout_height="44dp" android:text="本机测试：弹窗并打开目标 App" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView android:id="@+id/sectionLife" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="生活状态" android:textStyle="bold" android:textSize="20sp" android:textColor="#FF3E514B" />
                    <TextView android:id="@+id/lifeStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="生活状态加载中…" android:textSize="13sp" android:textColor="#FF4F5F5A" android:background="#FFF1F6F4" android:padding="10dp" android:layout_marginTop="5dp" android:lineSpacingExtra="3dp" />
                    <Button android:id="@+id/refreshLifeButton" android:layout_width="match_parent" android:layout_height="44dp" android:text="保存设置并刷新状态" android:textSize="14sp" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="回家模式" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="检测到你在指定娱乐 App 停太久，就发悬浮横幅提醒；开启强制抱回后会直接打开目标 App。" android:textSize="13sp" android:textColor="#FF7A8F89" android:layout_marginTop="5dp" android:lineSpacingExtra="4dp" />
                    <TextView android:id="@+id/homeModeStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="回家模式加载中…" android:textSize="12sp" android:textColor="#FF4F5F5A" android:background="#FFF1F6F4" android:padding="10dp" android:layout_marginTop="5dp" android:lineSpacingExtra="3dp" />
                    <CheckBox android:id="@+id/homeModeEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="开启回家模式" android:textSize="15sp" android:layout_marginTop="5dp" />
                    <CheckBox android:id="@+id/homeModeForceEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="自动打开：提醒后直接打开目标 App" android:textSize="15sp" />
                    <EditText android:id="@+id/homeWatchPackagesInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="盯住包名，逗号分隔，例如 抖音,小红书包名" android:textSize="14sp" android:singleLine="false" />
                    <EditText android:id="@+id/homeThresholdInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="超过几分钟触发，默认 10" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                    <EditText android:id="@+id/homeCooldownInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="冷却几分钟，默认 5" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                    <EditText android:id="@+id/homeTargetInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="目标 App 包名，可留空；例如 com.example.app" android:textSize="14sp" android:singleLine="true" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="城市与天气备注" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <EditText android:id="@+id/cityInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="城市，例如 石家庄" android:textSize="14sp" android:singleLine="true" android:layout_marginTop="5dp" />
                    <EditText android:id="@+id/weatherInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="天气备注，例如 晴，33°C" android:textSize="14sp" android:singleLine="true" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="主动提醒规则" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="这些提醒现在会优先像微信消息一样弹顶部横幅，而不是整页打断。" android:textSize="13sp" android:textColor="#FF7A8F89" android:layout_marginTop="5dp" android:lineSpacingExtra="4dp" />
                    <CheckBox android:id="@+id/remindersEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="开启主动提醒总开关" android:textSize="15sp" android:checked="true" android:layout_marginTop="5dp" />
                    <CheckBox android:id="@+id/batteryRuleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="低电量提醒" android:textSize="15sp" android:checked="true" />
                    <EditText android:id="@+id/batteryThresholdInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="低电量阈值%，默认 20" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                    <CheckBox android:id="@+id/screenRuleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="今日屏幕时间提醒" android:textSize="15sp" android:checked="true" />
                    <EditText android:id="@+id/screenThresholdInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="今日屏幕时间阈值分钟，默认 240" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                    <CheckBox android:id="@+id/waterRuleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="喝水提醒" android:textSize="15sp" />
                    <EditText android:id="@+id/waterIntervalInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="喝水间隔分钟，默认 120" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                    <CheckBox android:id="@+id/restRuleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="休息眼睛提醒" android:textSize="15sp" android:checked="true" />
                    <EditText android:id="@+id/restIntervalInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="休息提醒间隔分钟，默认 90" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="生理期提醒" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <CheckBox android:id="@+id/cycleEnabled" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="开启生理期提醒" android:textSize="15sp" android:layout_marginTop="5dp" />
                    <EditText android:id="@+id/lastPeriodStartInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="上次开始日期 yyyy-MM-dd" android:textSize="14sp" android:singleLine="true" />
                    <EditText android:id="@+id/cycleLengthInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="平均周期天数，默认 30" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                    <EditText android:id="@+id/periodLengthInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="一般来几天，默认 6" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                    <EditText android:id="@+id/cycleRemindBeforeInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="提前几天提醒，默认 3" android:textSize="14sp" android:inputType="number" android:singleLine="true" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="提醒测试" android:textStyle="bold" android:textSize="17sp" android:textColor="#FF3E514B" />
                    <Button android:id="@+id/alarmTestButton" android:layout_width="match_parent" android:layout_height="44dp" android:text="本机测试：定一分钟后的闹钟" android:textSize="14sp" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                    <Button android:id="@+id/notifyTestButton" android:layout_width="match_parent" android:layout_height="44dp" android:text="本机测试：悬浮横幅提醒" android:textSize="14sp" android:background="@drawable/pill_soft" android:layout_marginTop="5dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView android:id="@+id/sectionDebug" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="调试日志" android:textStyle="bold" android:textSize="20sp" android:textColor="#FF3E514B" />
                    <TextView android:id="@+id/debugText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="等待调试信息…" android:textSize="12sp" android:textColor="#FF4F5F5A" android:background="#FFF1F6F4" android:padding="12dp" android:layout_marginTop="5dp" android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="62dp" android:orientation="horizontal" android:gravity="center" android:paddingLeft="8dp" android:paddingRight="8dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:background="@drawable/bottom_bar_bg">
        <Button android:id="@+id/tabSettings" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="设置" android:textSize="12sp" android:background="@drawable/pill_soft" />
        <Button android:id="@+id/tabSee" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="看见" android:textSize="12sp" android:layout_marginLeft="4dp" android:background="@drawable/pill_soft" />
        <Button android:id="@+id/tabControl" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="控制" android:textSize="12sp" android:layout_marginLeft="4dp" android:background="@drawable/pill_soft" />
        <Button android:id="@+id/tabLife" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="状态" android:textSize="12sp" android:layout_marginLeft="4dp" android:background="@drawable/pill_soft" />
        <Button android:id="@+id/tabDebug" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="日志" android:textSize="12sp" android:layout_marginLeft="4dp" android:background="@drawable/pill_soft" />
    </LinearLayout>
</LinearLayout>
